{
  "name": "node-sass",
  "version": "9.0.2",
  "libsass": "3.5.5",
  "description": "Wrapper around libsass with extended support beyond Node.js 20+",
  "license": "MIT",
  "bugs": "https://github.com/HydraOrc/node-sass/issues",
  "homepage": "https://github.com/HydraOrc/node-sass",
  "repository": {
    "type": "git",
    "url": "https://github.com/HydraOrc/node-sass"
  },
  "author": {
    "name": "Andrew Nesbitt",
    "email": "andrewnez@gmail.com",
    "url": "https://andrew.github.com"
  },
  "contributors": [{
    "name": "Andrew Nesbitt",
    "email": "andrewnez@gmail.com",
    "url": "https://andrew.github.com"
  }, {
    "name":"Ruslan Hydra",
    "url":"https://github.com/HydraOrc"
  }],
  "engines": {
    "node": ">=16"
  },
  "main": "lib/index.js",
  "nodeSassConfig": {
    "binarySite": "https://github.com/HydraOrc/node-sass/tree/master/vendor"
  },
  "bin": {
    "node-sass": "bin/node-sass"
  },
  "gypfile": true,
  "scripts": {
    "coverage": "nyc npm run test",
    "install": "node scripts/install.js",
    "postinstall": "node scripts/build.js",
    "lint": "eslint bin/node-sass lib scripts test",
    "test": "mocha test/{*,**/**}.js",
    "build": "node scripts/build.js --force",
    "prepublishOnly ": "scripts/prepublish.js"
  },
  "files": [
    "bin",
    "binding.gyp",
    "lib",
    "scripts",
    "src",
    "test",
    "vendor"
  ],
  "keywords": [
    "css",
    "libsass",
    "preprocessor",
    "sass",
    "scss",
    "style"
  ],
  "dependencies": {
    "async-foreach": "^0.1.3",
    "chalk": "^4.1.2",
    "cross-spawn": "^7.0.3",
    "gaze": "^1.0.0",
    "get-stdin": "^4.0.1",
    "glob": "^7.0.3",
    "lodash": "^4.17.15",
    "make-fetch-happen": "~13.0.1",
    "meow": "^9.0.0",
    "nan": "^2.17.0",
    "node-gyp": "^10.0.1",
    "sass-graph": "^4.0.1",
    "stdout-stream": "~2.0.0",
    "true-case-path": "^2.2.1"
  },
  "devDependencies": {
    "eslint": "^8.0.0",
    "fs-extra": "~11.2.0",
    "mocha": "~10.4.0",
    "nyc": "~17.0.0",
    "rimraf": "^3.0.2",
    "unique-temp-dir": "^1.0.0"
  }
}
